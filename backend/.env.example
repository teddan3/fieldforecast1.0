# Laravel
APP_NAME="Field Forecast"
APP_ENV=local
APP_KEY=base64:CHANGE_ME
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_CHANNEL=stack
CMS_ADMIN_NAME="Field Forecast Admin"
CMS_ADMIN_EMAIL=admin@fieldforecast.local
CMS_ADMIN_PASSWORD=CHANGE_ME_NOW

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=field_forecast
DB_USERNAME=root
DB_PASSWORD=CHANGE_ME

# Odds API (example: The Odds API)
ODDS_API_BASE_URL="https://api.the-odds-api.com/v4"
ODDS_API_KEY="CHANGE_ME"

# Sport keys to fetch (used by FetchOddsCommand)
ODDS_API_SPORT_KEYS="soccer_epl,soccer_uefa_champs_league"
